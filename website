<!DOCTYPE html>
<html>
<head>
    <title>Websites for Small Businesses</title>
    <style>
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f4f6f8;
            margin: 0;
            color: #333;
            text-align: center;
        }

        /* Flashy animated gradient header */
        @keyframes gradientBG {
            0% {background-position: 0% 50%;}
            50% {background-position: 100% 50%;}
            100% {background-position: 0% 50%;}
        }

        @keyframes fadeIn {
            to { opacity: 1; }
        }

        header {
            height: 100vh; /* Full screen header */
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            color: white;
            text-align: center;
            background: linear-gradient(-45deg, #3498db, #e67e22, #9b59b6, #1abc9c);
            background-size: 400% 400%;
            animation: gradientBG 15s ease infinite;
        }

        header h1 {
            font-size: 4em;
            text-shadow: 2px 2px 10px rgba(0,0,0,0.5);
            margin: 0;
            animation: fadeIn 2s ease forwards;
            opacity: 0;
        }

        header p {
            font-size: 1.5em;
            margin-top: 20px;
            text-shadow: 1px 1px 6px rgba(0,0,0,0.4);
            animation: fadeIn 2.5s ease forwards;
            opacity: 0;
        }

        /* Main content container */
        .container {
            max-width: 900px;
            margin: 50px auto;
            padding: 0 20px;
        }

        .box {
            background: white;
            margin: 25px 0;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 8px 20px rgba(0,0,0,0.1);
            transition: transform 0.3s, box-shadow 0.3s;
        }

        .box:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 25px rgba(0,0,0,0.15);
        }

        .box h2 {
            color: #3498db;
            margin-top: 0;
        }

        button {
            background-color: #e67e22;
            color: white;
            padding: 15px 35px;
            border: none;
            border-radius: 8px;
            font-size: 1.1em;
            cursor: pointer;
            transition: background 0.3s, transform 0.2s;
            margin-top: 15px;
        }

        button:hover {
            background-color: #d35400;
            transform: scale(1.05);
        }

        .examples, .pricing {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin: 40px 0;
        }

        .example-card, .pricing-card {
            background: white;
            width: 250px;
            padding: 20px;
            border-radius: 12px;
            box-shadow: 0 6px 15px rgba(0,0,0,0.1);
            transition: transform 0.3s;
        }

        .example-card:hover, .pricing-card:hover {
            transform: translateY(-5px);
        }

        .example-card img {
            width: 100%;
            border-radius: 10px;
        }

        .pricing-card h3 {
            color: #3498db;
            margin-top: 0;
        }

        .price {
            font-size: 2em;
            margin: 15px 0;
        }

        .features {
            text-align: left;
            margin: 15px 0;
        }

        .features p {
            margin: 5px 0;
        }

        footer {
            margin-top: 50px;
            padding: 30px 20px;
            background-color: #2c3e50;
            color: white;
            font-size: 0.9em;
        }

        footer h2 {
            color: #e67e22;
            margin-top: 0;
        }

    </style>
</head>
<body>

    <!-- Flashy Header -->
    <header>
        <h1>I Build Websites for Small Businesses</h1>
        <p>Fast, clean, and professional websites to grow your business</p>
    </header>

    <div class="container">
        <!-- Services -->
        <div class="box">
            <h2>What I Offer</h2>
            <p>✔ 1-page business websites</p>
            <p>✔ Mobile-friendly design</p>
            <p>✔ Fast delivery</p>
        </div>

        <div class="box">
            <h2>Why Choose Me</h2>
            <p>✔ Quick turnaround</p>
            <p>✔ Simple and effective design</p>
            <p>✔ Starting at just $100</p>
        </div>

        <!-- Pricing -->
        <h2>Pricing Plans</h2>
        <div class="pricing">
            <div class="pricing-card">
                <h3>Basic</h3>
                <div class="price">$100</div>
                <div class="features">
                    <p>✔ 1-page website</p>
                    <p>✔ Mobile-friendly</p>
                    <p>✔ Delivered in 3 days</p>
                </div>
                <button>Select</button>
            </div>
            <div class="pricing-card">
                <h3>Standard</h3>
                <div class="price">$200</div>
                <div class="features">
                    <p>✔ 3-page website</p>
                    <p>✔ Mobile-friendly</p>
                    <p>✔ Contact form & map</p>
                    <p>✔ Delivered in 5 days</p>
                </div>
                <button>Select</button>
            </div>
            <div class="pricing-card">
                <h3>Premium</h3>
                <div class="price">$300</div>
                <div class="features">
                    <p>✔ 5-page website</p>
                    <p>✔ Mobile-friendly</p>
                    <p>✔ Contact form & map</p>
                    <p>✔ Basic SEO & analytics</p>
                    <p>✔ Delivered in 7 days</p>
                </div>
                <button>Select</button>
            </div>
        </div>

        <!-- Example Websites -->
        <h2>Example Websites I've Made</h2>
        <div class="examples">
            <div class="example-card">
                <img src="https://via.placeholder.com/250x150.png?text=Website+1" alt="Example 1">
                <p>Simple Business Landing Page</p>
            </div>
            <div class="example-card">
                <img src="https://via.placeholder.com/250x150.png?text=Website+2" alt="Example 2">
                <p>Mobile-Friendly Site</p>
            </div>
        </div>

        <!-- Contact Section -->
        <footer>
            <h2>Contact Me</h2>
            <p>Email: crosier8660@gmail.com</p>
            <button>Get a Website</button>
            <p>&copy; 2026 Colton Rosier. All rights reserved.</p>
        </footer>

    </div>

</body>
</html>
